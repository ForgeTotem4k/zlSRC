<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="overlay" prefHeight="520.0" prefWidth="450.0" styleClass="transparent" stylesheets="@processing.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">

    <AnchorPane id="header" minHeight="10.0" prefHeight="34.0" prefWidth="341.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
      <padding>
         <Insets top="10.0" />
      </padding>
      <children>
           <!-- Кнопки управления -->
           <HBox id="controls" layoutX="318.0" layoutY="2.0" prefHeight="37.0" prefWidth="132.0" spacing="10.0" visible="false" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="2.0">
               <fx:include source="../../components/buttons/cancel.fxml" visible="false" />
               <fx:include source="../../components/buttons/minimize.fxml" />
               <fx:include source="../../components/buttons/exit.fxml" />
            <padding>
               <Insets top="5.0" />
            </padding>
           </HBox>
      </children>
    </AnchorPane>
    <VBox alignment="CENTER" AnchorPane.bottomAnchor="50.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0">
        <children>
            <Label id="header-text" alignment="CENTER" prefHeight="131.0" prefWidth="390.0" text="%runtime.overlay.processing.processing.description" />
            <!-- Описание процесса -->
            <Label id="description" alignment="CENTER" contentDisplay="CENTER" textAlignment="CENTER" wrapText="true" />
        </children>
    </VBox>
    <HBox alignment="CENTER" layoutY="63.0" minHeight="-Infinity" prefHeight="120.0" prefWidth="450.0" AnchorPane.bottomAnchor="337.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="63.0">
        <children>
            <ImageView id="logo" pickOnBounds="true" preserveRatio="true">
                <image>
                    <Image url="@../../images/logo.png" />
                </image>
            </ImageView>
        </children>
    </HBox>
</AnchorPane>
