<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<HBox alignment="CENTER_RIGHT" minHeight="94.0" minWidth="273.0" spacing="15.0" styleClass="passwordPane" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <ImageView pickOnBounds="true" preserveRatio="true">
         <HBox.margin>
            <Insets />
         </HBox.margin>
         <image>
            <Image url="@../../../images/icons/user.png" />
         </image>
      </ImageView>
      <VBox fx:id="passwordMethod" alignment="CENTER" prefHeight="66.0" prefWidth="155.0" spacing="10.0" styleClass="transparent">
          <TextField fx:id="login" id="login" maxHeight="27.0" maxWidth="1.7976931348623157E308" minHeight="30.0" promptText="%runtime.scenes.login.login" stylesheets="@../login.css">
            <font>
               <Font size="13.0" />
            </font></TextField>
          <PasswordField  fx:id="password"  id="password" minHeight="30.0" promptText="%runtime.scenes.login.password" stylesheets="@../login.css">
            <font>
               <Font size="13.0" />
            </font></PasswordField>
         <HBox.margin>
            <Insets right="20.0" />
         </HBox.margin>
      </VBox>
   </children>
</HBox>
